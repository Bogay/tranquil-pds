{
  "db_name": "PostgreSQL",
  "query": "SELECT u.did, u.deactivated_at, u.takedown_ref, r.repo_root_cid, r.repo_rev\n               FROM repos r\n               JOIN users u ON r.user_id = u.id\n               WHERE u.did > $1\n               ORDER BY u.did ASC\n               LIMIT $2",
