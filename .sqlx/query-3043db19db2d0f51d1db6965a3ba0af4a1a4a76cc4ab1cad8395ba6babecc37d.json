  "query": "\n            SELECT u.id, u.did, u.backup_enabled, u.deactivated_at, r.repo_root_cid, r.repo_rev\n            FROM users u\n            JOIN repos r ON r.user_id = u.id\n            WHERE u.did = $1\n            ",
