  "query": "SELECT u.id, u.did, u.handle, u.email, u.deactivated_at, u.takedown_ref, u.is_admin,\n                      k.key_bytes, k.encryption_version\n               FROM users u\n               JOIN user_keys k ON u.id = k.user_id\n               WHERE u.did = $1",
