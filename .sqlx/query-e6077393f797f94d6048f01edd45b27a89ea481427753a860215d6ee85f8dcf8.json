  "query": "SELECT u.deactivated_at, u.takedown_ref, u.is_admin,\n                          k.key_bytes as \"key_bytes?\", k.encryption_version as \"encryption_version?\"\n                   FROM users u\n                   LEFT JOIN user_keys k ON u.id = k.user_id\n                   WHERE u.did = $1",
