{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                delegated_did,\n                actor_did,\n                controller_did,\n                action_type as \"action_type: PgDelegationActionType\",\n                action_details,\n                ip_address,\n                user_agent,\n                created_at\n            FROM delegation_audit_log\n            WHERE delegated_did = $1\n            ORDER BY created_at DESC\n            LIMIT $2 OFFSET $3\n            ",
