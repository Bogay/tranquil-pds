{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT s.did, u.id as user_id, u.email, u.handle, k.key_bytes\n        FROM sessions s\n        JOIN users u ON s.did = u.did\n        JOIN user_keys k ON u.id = k.user_id\n        WHERE s.access_jwt = $1\n        ",
